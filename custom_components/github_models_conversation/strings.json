{
  "config": {
    "step": {
      "user": {
        "title": "GitHub Models",
        "description": "Enter your GitHub personal access token. It requires the **models:read** permission for fine-grained tokens. Classic tokens work without any additional scope.",
        "data": {
          "api_key": "GitHub Personal Access Token"
        }
      }
    },
    "error": {
      "cannot_connect": "Failed to connect to GitHub Models API",
      "invalid_auth": "Invalid GitHub personal access token",
      "unknown": "Unexpected error"
    },
    "abort": {
      "already_configured": "This integration is already configured"
    }
  },
  "config_subentries": {
    "ai_task_data": {
      "abort": {
        "entry_not_loaded": "The integration is not loaded. Please ensure it is set up before adding agents.",
        "reconfigure_successful": "[%key:common::config_flow::abort::reconfigure_successful%]",
        "cannot_connect": "Failed to connect to GitHub Models API",
        "unknown": "Unexpected error"
      },
      "entry_type": "AI task",
      "initiate_flow": {
        "user": "Add AI task"
      },
      "step": {
        "init": {
          "data": {
            "name": "[%key:common::config_flow::data::name%]",
            "recommended": "Recommended model settings"
          }
        },
        "advanced": {
          "title": "Advanced settings",
          "data": {
            "chat_model": "[%key:common::generic::model%]",
            "temperature": "Temperature",
            "top_p": "Top P",
            "max_tokens": "Maximum tokens to return in response"
          }
        }
      }
    },
    "conversation": {
      "abort": {
        "entry_not_loaded": "The integration is not loaded. Please ensure it is set up before adding agents.",
        "reconfigure_successful": "[%key:common::config_flow::abort::reconfigure_successful%]",
        "cannot_connect": "Failed to connect to GitHub Models API",
        "unknown": "Unexpected error"
      },
      "entry_type": "Conversation agent",
      "initiate_flow": {
        "user": "Add conversation agent"
      },
      "step": {
        "init": {
          "data": {
            "name": "[%key:common::config_flow::data::name%]",
            "prompt": "[%key:common::config_flow::data::prompt%]",
            "llm_hass_api": "[%key:common::config_flow::data::llm_hass_api%]",
            "recommended": "Recommended model settings"
          },
          "data_description": {
            "prompt": "Instruct how the LLM should respond. This can be a template."
          }
        },
        "advanced": {
          "title": "Advanced settings",
          "data": {
            "chat_model": "[%key:common::generic::model%]",
            "temperature": "Temperature",
            "top_p": "Top P",
            "max_tokens": "Maximum tokens to return in response"
          }
        }
      }
    }
  }
}
